# Production site URL (used for canonical + OG meta tags)
# Set this in Vercel to your real *.vercel.app or custom domain URL.
NEXT_PUBLIC_SITE_URL=

# Google Gemini API key — get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Resend API key — get one free at https://resend.com/api-keys (100 emails/day free)
# For testing, the default "Portfolio <onboarding@resend.dev>" works without domain setup.
RESEND_API_KEY=

# Optional: override the "from" address (requires verified domain on Resend)
# RESEND_FROM=Portfolio <hi@yourdomain.com>
